# ============================================================
# Web app (Next.js) — copy this file to .env.frontend and
# fill in real values before running docker compose up.
# ============================================================

# API base URL — must be reachable from the browser, so use
# localhost (not the docker service name "api").
NEXT_PUBLIC_API_URL=http://localhost:8000/api

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PORTAL_LINK=
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_BYPASS_PAYMENT_CHECKS=true
NEXT_PUBLIC_BYPASS_AUTH=false
