# ============================================================
# Backend + Database — copy this file to .env.backend and
# fill in real values before running docker compose up.
# ============================================================

# ── PostgreSQL (used by both the db and api containers) ─────
# The postgres image reads POSTGRES_* vars; FastAPI reads DATABASE_*.
# Keep the values in sync between the two blocks below.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=videoscripts_dev_password
POSTGRES_DB=video_scripts

DATABASE_USER=postgres
DATABASE_PASSWORD=videoscripts_dev_password
DATABASE_NAME=video_scripts
DATABASE_HOST=db          # docker service name — do not change for local dev
DATABASE_PORT=5432

# ── App core ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth2 ───────────────────────────────────────────
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:3000/

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ── YouTube transcript proxy (optional) ─────────────────────
TRANSCRIPT_PROXY_USERNAME=
TRANSCRIPT_PROXY_PASSWORD=

# ── Brevo email (optional) ──────────────────────────────────
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@videoscripts.com

# ── AWS S3 (optional — local storage used when disabled) ────
USE_S3_FOR_STORAGE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ── CORS extra origins (comma-separated, optional) ──────────
CORS_EXTRA_ORIGINS=
