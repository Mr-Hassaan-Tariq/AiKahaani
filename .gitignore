# ==================================
# TubeGenius - Full-Stack .gitignore
# ==================================

# =====================================
# Operating System Files
# =====================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# =====================================
# Python/Django Backend
# =====================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# C extensions
*.so

# Django specific
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Django migrations (uncomment if you want to ignore them)
# */migrations/*.py
# */migrations/*.pyc
# !*/migrations/__init__.py

# Django static files
backend/static/
backend/staticfiles/
backend/media/

# Django secret key and settings
.env.backend
.env.django
secret_key.txt

# Database
data/
*.db
*.sqlite
*.sqlite3

# Python virtual environments
venv/
env/
ENV/
.venv/
.env/
.python-version

# UV package manager
.uv/
uv.lock

# Pytest
.pytest_cache/
.coverage
coverage.xml
*.cover
.hypothesis/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# =====================================
# Node.js/Next.js Frontend
# =====================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package managers
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
.pnpm-store

# Next.js
.next/
out/
build/
dist/
next-env.d.ts
*.tsbuildinfo

# Vercel
.vercel

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.frontend
.env*.local
.env.frontend.template

# Testing
coverage/
.nyc_output
*.lcov

# ESLint
.eslintcache

# TypeScript
*.tsbuildinfo

# =====================================
# Development Tools & IDEs
# =====================================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =====================================
# Docker & DevOps
# =====================================
# Docker
.dockerignore
docker-compose.override.yml
docker-compose.override.yaml

# Kubernetes
*.kubeconfig

# =====================================
# Certificates & Security
# =====================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# =====================================
# Build & Compilation
# =====================================
*.o
*.a
*.so
*.exe
*.dll

# =====================================
# Logs & Temporary Files
# =====================================
*.log
logs/
*.tmp
*.temp
.cache/

# =====================================
# Project Specific
# =====================================
# Development notes and TODO files
TODO.md
NOTES.md
.scratch/

# Generated API documentation
api-docs/

# Test uploads
test-uploads/

# Local configuration overrides
local_settings.py
settings_local.py
config_local.py

# Backup files
*.bak
*.backup
*.old

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# =====================================
# MacOS specific
# =====================================
.AppleDouble
.LSOverride
Icon

# =====================================
# Windows specific
# =====================================
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
